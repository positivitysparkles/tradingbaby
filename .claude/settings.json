{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoCompactThreshold": 197000,
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/stop-hook-git-check.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/compact-threshold-stop.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-compact-vault-backup.sh"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/post-compact-restore.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Skill"
    ]
  }
}
