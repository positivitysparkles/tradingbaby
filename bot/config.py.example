# ── PASTE YOUR KEYS HERE (never share this file) ─────────────────────────────
ALPACA_KEY_ID     = "PASTE_YOUR_KEY_ID"       # alpaca.markets → Paper Trading → API Keys
ALPACA_SECRET_KEY = "PASTE_YOUR_SECRET_KEY"
TELEGRAM_TOKEN    = "PASTE_YOUR_BOT_TOKEN"    # message @BotFather to get this
# ─────────────────────────────────────────────────────────────────────────────

TELEGRAM_CHAT_ID  = "8223032422"   # already set up ✓

# Alpaca endpoints (paper trading)
ALPACA_BASE_URL = "https://paper-api.alpaca.markets"
ALPACA_DATA_URL = "https://data.alpaca.markets"

# Trade rules (W118 system)
MAX_DAILY_TRADES  = 9999      # effectively unlimited — MAX_POSITIONS is the real risk control
MAX_POSITIONS     = 5         # max simultaneous open positions (the real guard; 5 = wider net for the paper learning phase, drop to 3 for "realistic money")
DOLLARS_PER_TRADE = 100       # base trade size; the Edge Engine scales this by grade (below)
STOP_PCT          = 0.08      # -8% hard stop
T1_PCT            = 0.15      # +15% first target
T2_PCT            = 0.30      # +30% second target
T3_PCT            = 0.60      # +60% third target

# ── Edge Engine — self-improving "learn, then tighten" loop ───────────────────
# OPTIONAL: the bot bakes in identical defaults, so you do NOT need to add these to
# your live config.py — they're here only if you want to tune later.
#
# Grade-scaled sizing: A+ presses harder, weaker setups risk less, ALWAYS clamped to
# [DOLLARS_MIN, DOLLARS_MAX] so a single trade can never exceed the ceiling.
DOLLARS_BY_GRADE   = {"A+": 150, "A": 100, "B": 60, "C": 50}
DOLLARS_MIN        = 50        # hard floor per trade
DOLLARS_MAX        = 200       # hard ceiling per trade — never exceeded, whatever the table says
#
# Learn → tighten: take every valid signal until LEARN_THRESHOLD closed trades exist
# (gathering data), then auto-buy only grades proven to win (win-rate ≥
# EDGE_WINRATE_FLOOR over ≥ EDGE_MIN_SAMPLE trades). Restrict-only — it can drop a
# weak setup to a manual alert but never loosens a rule or raises a cap.
LEARN_THRESHOLD    = 30        # closed trades before the bot starts tightening
EDGE_WINRATE_FLOOR = 0.45      # a grade must win ≥45% (over enough trades) to stay auto-buy
EDGE_MIN_SAMPLE    = 8         # need ≥8 closed trades on a grade before judging it
CATALYST_PROXY     = True      # price-action catalyst detection (gap / halt-resume / runner)

# Scanner filters (W118 universe — matches Colab scanner exactly)
MIN_PRICE         = 0.10
MAX_PRICE         = 15.00     # matches TradingView Yassss screen
MAX_FLOAT         = 20_000_000 # float < 20M shares — low float = explosive moves
MIN_CHANGE_PCT    = 10.0      # minimum % gain to consider
MIN_ABS_VOLUME    = 1_000_000 # absolute volume floor (HTLM lesson)
REL_VOL_MIN       = 1.5       # relative volume minimum — matches Colab grader (was 4.0, too strict, blocked nearly every entry)
SCAN_INTERVAL_MIN = 1         # how often to scan in minutes

# Time gate (UTC). Summer: MT = UTC-6, ET = UTC-4
GATE_OPEN_UTC  = 8            # 2:00am MT / 4:00am ET  (premarket start)
GATE_CLOSE_UTC = 22           # 4:00pm MT / 6:00pm ET  (run all day, end at MT close)

# Session timing — avoid the midday chop (W118: 56% of wins are premarket;
# 10:30am-3pm ET is the dead zone). NEW ENTRIES are paused midday; exits on
# open positions ALWAYS run regardless of time. Power hour (3-4pm) stays open.
AVOID_MIDDAY    = False
MIDDAY_START_ET = 10.5        # 10:30am ET — entries pause
MIDDAY_END_ET   = 15.0        # 3:00pm ET  — entries resume (power hour)

# Entry quality — deep-curl flag (informational only, no gate). StochRSI K that
# recently dipped near 0 then curled up = stronger reload (Colab grader's ⭐).
# Shown in alerts + logged so the audit can learn if deep curls win more often.
DEEP_CURL_RESET = 20.0        # K dipped below this in the lookback = deep curl

# Extended-hours fills — Alpaca CANNOT fill market orders outside 9:30am-4pm ET.
# In premarket/afterhours the bot must use a LIMIT order + extended_hours=True.
# This buffer sets the limit price above last (last × 1.02) so the order is
# "marketable" and actually fills in thin premarket — W118's best window.
EXT_HOURS_LIMIT_BUFFER = 0.02 # pay up to +2% above last to guarantee a premarket fill

# Entry timing — 1-minute freshness gate (W118's "zoom to 1m"). The 5-min signal
# lags; this blocks entries where the 1-min move is already rolling over (no more
# buying the top like the ATPC $3.43 chase). Fails open on thin 1-min history.
REQUIRE_1M_FRESH = False

# Supabase — dedicated tradingbaby project (supabase.com → "tradingbaby" → Settings → API)
# SUPABASE_KEY = service_role (secret) key — bot writes trades.
# The anon (public) key goes in the dashboard .env.local — never here.
SUPABASE_URL      = "https://lgzzuppprbokfobhycov.supabase.co"
SUPABASE_KEY      = "PASTE_YOUR_SERVICE_ROLE_KEY"  # Settings → API → service_role secret
