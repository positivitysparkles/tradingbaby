[Unit]
Description=W118 Curl if Flow Auto Trading Bot
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/tradingbaby
ExecStart=/usr/bin/python3 /root/tradingbaby/bot/bot.py
Restart=always
RestartSec=30
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
