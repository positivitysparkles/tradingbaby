// Weatherman118 "Curl if Flow" v5.1 — A+ SHELF BOUNCE
// Reverse-engineered by positivitysparkles | v5.1 2026-06-19 17:55 UTC
// 5m chart | Supertrend + ZLSMA-50 + StochRSI + MACD(5,10,16) + Session VWAP + Chandelier Exit
// INTRADAY ONLY — close same day, never hold overnight.
//
// This is the EXACT system the Python bot (bot/indicators.py) runs, so chart and bot agree.
//
// CONDITION PRIORITY TIERS (which of the 6 are MUST vs soft):
//   Tier 1 — STRUCTURE (hard MUST): Supertrend green · above VWAP · above ZLSMA-50
//   Tier 2 — IGNITION (entry timing): StochRSI hook (K>D & rising) · MACD hist>0
//   Tier 3 — SOFT: Volume>1.5x (dries up in the coil!) · MACD line>0
//
// v5.1 CHANGE: 🌀 COIL marker — Tier-1 + hook + MACD pass but volume still drying up
//   (the dry coil BEFORE the breakout candle). A manual cue, not an auto-entry — matches
//   the bot's COIL alert. Volume surge prints on the next candle.
//
// v5 CHANGES (from the June-19 chart study — ATPC +42%, CRVO, CDT +47%):
//   + Session VWAP gate (Source=HL2): price must HOLD above VWAP (0.5% tolerance).
//     This is the line that separated every runner from the WKSP chop.
//   + Chandelier Exit (ATR 10, mult 2): ride the runner until a full candle closes
//     below the green CE line — the real trailing stop.
//   + MACD switched to (5,10,16): line>0 AND hist>0 (faster, fires with Supertrend).
//   + Reset zone widened to K<=30 (the CDT A+ entry was K=33.9 — <25 would miss it).
//   + A+ "Shelf Bounce" star = full pass + deep curl (K reset <=30) + above VWAP.
//@version=5
strategy("W118 Curl if Flow v5 — Shelf Bounce", overlay=true, max_labels_count=500,
         default_qty_type=strategy.percent_of_equity, default_qty_value=25,
         pyramiding=0, calc_on_every_tick=false)

// ─── INPUTS ───────────────────────────────────────────────────────────────────
// Supertrend (PRIMARY trigger)
st_atr   = input.int(10,    "Supertrend ATR Period", group="Supertrend")
st_mult  = input.float(2.0, "Supertrend Multiplier", group="Supertrend")
// ZLSMA-50
zl_len   = input.int(50,    "ZLSMA Length",          group="ZLSMA-50")
// StochRSI (3,3,14,14)
rsi_len  = input.int(14,    "RSI Length",            group="StochRSI")
sto_len  = input.int(14,    "Stoch Length",          group="StochRSI")
k_smooth = input.int(3,     "K Smooth",              group="StochRSI")
d_smooth = input.int(3,     "D Smooth",              group="StochRSI")
reset_zn = input.float(30.0,"Deep-curl reset (K <=)",group="StochRSI")
curl_lb  = input.int(12,    "Curl lookback (bars)",  group="StochRSI")
// MACD (5,10,16)
m_fast   = input.int(5,     "MACD Fast",             group="MACD")
m_slow   = input.int(10,    "MACD Slow",             group="MACD")
m_sig    = input.int(16,    "MACD Signal",           group="MACD")
// Volume
vol_mult = input.float(1.5, "Rel Vol min (x20-bar)", group="Volume")
vol_lb   = input.int(20,    "Volume Lookback",       group="Volume")
// Session VWAP
vwap_tol = input.float(0.5, "VWAP tolerance %",      group="VWAP") / 100.0
use_vwap = input.bool(true, "Require above VWAP",    group="VWAP")
// Chandelier Exit
ce_atr   = input.int(10,    "Chandelier ATR",        group="Chandelier Exit")
ce_mult  = input.float(2.0, "Chandelier Multiplier", group="Chandelier Exit")
// Exit targets
stop_pct = input.float(8.0, "Stop Loss %",           group="Exits")
t1_pct   = input.float(15.0,"T1 Target %",           group="Exits")
t2_pct   = input.float(30.0,"T2 Target %",           group="Exits")
t3_pct   = input.float(60.0,"T3 Target %",           group="Exits")

// ─── 1. SUPERTREND ────────────────────────────────────────────────────────────
[st_line, st_dir] = ta.supertrend(st_mult, st_atr)   // source = hl2; dir<0 = bullish
st_bull   = st_dir < 0
st_flip   = st_bull and not st_bull[1]               // fresh green flip = the trigger

// ─── 2. ZLSMA-50 ──────────────────────────────────────────────────────────────
e1     = ta.ema(close, zl_len)
e2     = ta.ema(e1, zl_len)
zlsma  = 2 * e1 - e2
above_zlsma = close > zlsma

// ─── 3. StochRSI K>D AND rising ───────────────────────────────────────────────
rsi_v  = ta.rsi(close, rsi_len)
k      = ta.sma(ta.stoch(rsi_v, rsi_v, rsi_v, sto_len), k_smooth)
d      = ta.sma(k, d_smooth)
stoch_ok   = k > d and k > k[1]                      // crossed up AND still rising
k_low      = ta.lowest(k, curl_lb)
deep_curl  = k_low <= reset_zn                       // reloaded low then curling = ⭐

// ─── 4. MACD(5,10,16): line>0 AND hist>0 ──────────────────────────────────────
[m_line, m_signal, m_hist] = ta.macd(close, m_fast, m_slow, m_sig)
macd_ok = m_line > 0 and m_hist > 0

// ─── 5. Volume > 1.5x 20-bar average ──────────────────────────────────────────
avg_vol = ta.sma(volume, vol_lb)
rel_vol = avg_vol > 0 ? volume / avg_vol : 0.0
vol_ok  = rel_vol >= vol_mult

// ─── 6. Session VWAP (Source=HL2) — the shelf support ─────────────────────────
vwap_v     = ta.vwap(hl2)
above_vwap = close >= vwap_v * (1 - vwap_tol)
vwap_pass  = not use_vwap or above_vwap

// ─── CHANDELIER EXIT (ATR 10/2, use-close for extremums) ──────────────────────
ce_atr_v   = ta.atr(ce_atr)
ce_raw     = ta.highest(close, ce_atr) - ce_mult * ce_atr_v
var float ce_long = na
ce_long := close[1] > nz(ce_long[1], ce_raw) ? math.max(ce_raw, nz(ce_long[1], ce_raw)) : ce_raw
ce_bull = close > ce_long

// ─── ENTRY ────────────────────────────────────────────────────────────────────
all_ok      = st_bull and above_zlsma and stoch_ok and macd_ok and vol_ok and vwap_pass
entry_fresh = all_ok and (st_flip or not all_ok[1])  // rising edge / fresh trigger
a_plus      = all_ok and deep_curl and above_vwap    // the A+ Shelf Bounce

// Coil near-miss — Tier-1 (Supertrend+VWAP+ZLSMA) + Stoch hook + MACD all pass, only
// VOLUME short (the dry coil before the breakout). Manual cue, NOT an auto-entry.
tier1_ok  = st_bull and above_zlsma and vwap_pass
coil_near = tier1_ok and stoch_ok and macd_ok and not vol_ok

// ─── EXIT (matches bot check_exit_signal: ST bearish | below ZLSMA | chandelier) ─
exit_struct = (not st_bull) or (close < zlsma) or (not ce_bull)

// ─── STRATEGY ORDERS ──────────────────────────────────────────────────────────
if entry_fresh and strategy.position_size == 0
    strategy.entry("Long", strategy.long)
    strategy.exit("Stop/T",  from_entry="Long",
                  stop  = close * (1 - stop_pct/100),
                  limit = close * (1 + t3_pct/100))
if strategy.position_size > 0 and exit_struct
    strategy.close("Long", comment="exit")

// ─── PLOTS ────────────────────────────────────────────────────────────────────
plot(zlsma,   "ZLSMA-50",     color=color.yellow, linewidth=2)
plot(vwap_v,  "Session VWAP", color=color.new(color.blue, 0), linewidth=1)
plot(ce_long, "Chandelier",   color=ce_bull ? color.new(color.green, 0) : color.new(color.red, 0), linewidth=1)

plotshape(entry_fresh and not a_plus, "BUY",   shape.triangleup,   location.belowbar, color.new(color.green, 0), size=size.small, text="BUY")
plotshape(entry_fresh and a_plus,     "A+ BUY",shape.triangleup,   location.belowbar, color.new(color.lime,  0), size=size.small, text="A+")
plotshape(strategy.position_size > 0 and exit_struct and not exit_struct[1], "EXIT", shape.triangledown, location.abovebar, color.new(color.red, 0), size=size.small, text="EXIT")
plotchar(a_plus, "A+ star", "★", location.belowbar, color.new(color.lime, 0), size=size.tiny)
plotchar(coil_near and not a_plus, "Coil", "🌀", location.belowbar, color.new(color.orange, 0), size=size.tiny)

bgcolor(all_ok ? color.new(color.green, 92) : na, title="All conditions met")

// ─── ALERTS (set these on TradingView so chart + bot agree) ───────────────────
alertcondition(entry_fresh,            "W118 Entry",    'W118 BUY {{ticker}} @ {{close}}')
alertcondition(entry_fresh and a_plus, "W118 A+ Entry", 'W118 A+ SHELF BOUNCE {{ticker}} @ {{close}}')
alertcondition(coil_near,              "W118 Coil",     'W118 COIL {{ticker}} @ {{close}} — only volume drying up, watch for break')
alertcondition(exit_struct,            "W118 Exit",     'W118 EXIT {{ticker}} @ {{close}}')
