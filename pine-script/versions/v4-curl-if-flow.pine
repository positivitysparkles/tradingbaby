// Weatherman118 "Curl if Flow" — NASDAQ Small-Cap Momentum System
// Reverse-engineered by positivitysparkles | v4 2026-05-03
// 5m chart | SHA + ZLSMA-50 + Stoch RSI
// INTRADAY ONLY — close same day, never hold overnight
//
// v4 CHANGES:
//   - Time gate now OFF by default (shows signals any time — you decide when to trade)
//   - Clear SELL labels at every exit: T1 trim, T2 full, Stop, SHA, K<20, ZLSMA
//   - SELL label shows actual % gain/loss at exit so you know exactly how the trade did
//   - Session tag on BUY label: [PM] [RTH] [OFF-HRS] so you still know context
//@version=5
strategy("W118 Curl if Flow v4", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=25)

// ─── INPUTS ───────────────────────────────────────────────────────────────────
sha_len1     = input.int(10,   "SHA Smooth 1",      group="Smoothed Heikin Ashi")
sha_len2     = input.int(10,   "SHA Smooth 2",      group="Smoothed Heikin Ashi")
zlsma_len    = input.int(50,   "ZLSMA Length",      group="ZLSMA-50")
rsi_len      = input.int(14,   "RSI Length",        group="Stoch RSI")
stoch_len    = input.int(14,   "Stoch Length",      group="Stoch RSI")
k_smooth     = input.int(3,    "K Smooth",          group="Stoch RSI")
d_smooth     = input.int(3,    "D Smooth",          group="Stoch RSI")
vol_mult     = input.float(1.5,"Volume Multiplier", group="Volume Filter")
vol_lookback = input.int(20,   "Volume Lookback",   group="Volume Filter")
stop_pct     = input.float(8.0,  "Stop Loss %",     group="Exits")
t1_pct       = input.float(15.0, "T1 Target %",     group="Exits")
t2_pct       = input.float(30.0, "T2 Target %",     group="Exits")
t3_pct       = input.float(60.0, "T3 Target %",     group="Exits")
trail_pct    = input.float(10.0, "Trail Stop %",    group="Exits")

// ─── FILTER RULES (toggle on/off) ────────────────────────────────────────────
use_k_depth   = input.bool(true,  "Rule 1: K depth filter (K was <10 before curl)",  group="Filters")
k_depth_max   = input.int(10,     "  Max K value 1-3 bars before cross",              group="Filters")
use_time_gate = input.bool(false, "Rule 2: Session gate (4am–10:30am ET only)",      group="Filters")
use_hard_t2   = input.bool(true,  "Rule 3: Hard T2 exit (100% at +30%, no T3)",     group="Filters")

// ─── SMOOTHED HEIKIN ASHI ─────────────────────────────────────────────────────
ha_close = (open + high + low + close) / 4
ha_open  = float(na)
ha_open  := na(ha_open[1]) ? (open + close) / 2 : (nz(ha_open[1]) + nz(ha_close[1])) / 2
ha_high  = math.max(high, math.max(ha_open, ha_close))
ha_low   = math.min(low,  math.min(ha_open, ha_close))

sha_close = ta.ema(ta.ema(ha_close, sha_len1), sha_len2)
sha_open  = ta.ema(ta.ema(ha_open,  sha_len1), sha_len2)
sha_high  = ta.ema(ta.ema(ha_high,  sha_len1), sha_len2)
sha_low   = ta.ema(ta.ema(ha_low,   sha_len1), sha_len2)

sha_green = sha_close > sha_open
sha_red   = sha_close < sha_open

plotcandle(sha_open, sha_high, sha_low, sha_close, "Smoothed HA",
     color      = sha_green ? color.new(color.green, 15) : color.new(color.red, 15),
     wickcolor  = sha_green ? color.new(color.green, 15) : color.new(color.red, 15),
     bordercolor= sha_green ? color.new(color.green, 15) : color.new(color.red, 15))

// ─── ZLSMA-50 ─────────────────────────────────────────────────────────────────
ema1  = ta.ema(close, zlsma_len)
ema2  = ta.ema(ema1,  zlsma_len)
zlsma = 2 * ema1 - ema2
plot(zlsma, "ZLSMA-50", color=color.yellow, linewidth=2)

above_zlsma = close > zlsma
bgcolor(above_zlsma ? color.new(color.green, 93) : color.new(color.red, 93), title="Flow Zone")

// ─── STOCHASTIC RSI ───────────────────────────────────────────────────────────
rsi_val     = ta.rsi(close, rsi_len)
stoch_k_raw = ta.stoch(rsi_val, rsi_val, rsi_val, stoch_len)
k = ta.sma(stoch_k_raw, k_smooth)
d = ta.sma(k, d_smooth)

// ─── VOLUME FILTER ────────────────────────────────────────────────────────────
avg_vol   = ta.sma(volume, vol_lookback)
vol_surge = volume >= avg_vol * vol_mult

// ─── FILTER CALCULATIONS ─────────────────────────────────────────────────────
k_was_low       = k[1] < k_depth_max or k[2] < k_depth_max or k[3] < k_depth_max
k_depth_ok      = not use_k_depth or k_was_low

bar_hour        = hour(time,   "America/New_York")
bar_minute      = minute(time, "America/New_York")
in_pm_session   = bar_hour >= 4  and bar_hour < 10
in_rth_session  = bar_hour == 9  and bar_minute >= 30 or bar_hour == 10 and bar_minute <= 30
in_fast_session = in_pm_session or in_rth_session
time_gate_ok    = not use_time_gate or in_fast_session

// ─── ENTRY CONDITIONS ─────────────────────────────────────────────────────────
k_curl_up    = ta.crossover(k, 20)
k_above_d    = k > d
sha_is_green = sha_green
price_in_flow= above_zlsma

base_signal  = k_curl_up and k_above_d and sha_is_green and price_in_flow and vol_surge
entry_signal = base_signal and k_depth_ok and time_gate_ok

// ─── SESSION TAG for BUY label ────────────────────────────────────────────────
session_tag = in_pm_session ? "PM" : in_rth_session ? "RTH" : "OFF-HRS"

// ─── STRATEGY ENTRY ───────────────────────────────────────────────────────────
if entry_signal and strategy.position_size == 0
    strategy.entry("Long", strategy.long)

var float entry_ref  = na
var line  stop_line  = na
var line  t1_line    = na
var line  t2_line    = na
var line  t3_line    = na

if strategy.position_size > 0 and strategy.position_size[1] == 0
    entry_ref := strategy.position_avg_price

// ─── EXIT LEVELS + LINES ─────────────────────────────────────────────────────
var float stop_level = na
var float t1_level   = na
var float t2_level   = na
var float t3_level   = na

if strategy.position_size > 0
    stop_level := entry_ref * (1 - stop_pct  / 100)
    t1_level   := entry_ref * (1 + t1_pct   / 100)
    t2_level   := entry_ref * (1 + t2_pct   / 100)
    t3_level   := entry_ref * (1 + t3_pct   / 100)

    if na(stop_line) or line.get_x2(stop_line) < bar_index
        stop_line := line.new(bar_index, stop_level, bar_index + 50, stop_level,
             color=color.red,   width=1, style=line.style_dashed)
        t1_line   := line.new(bar_index, t1_level,   bar_index + 50, t1_level,
             color=color.lime,  width=1, style=line.style_dashed)
        t2_line   := line.new(bar_index, t2_level,   bar_index + 50, t2_level,
             color=color.green, width=2, style=line.style_dashed)
        t3_line   := line.new(bar_index, t3_level,   bar_index + 50, t3_level,
             color=color.teal,  width=2, style=line.style_dashed)

    strategy.exit("Stop", "Long", stop=stop_level)
    if use_hard_t2
        strategy.exit("T1",    "Long", limit=t1_level, qty_percent=34)
        strategy.exit("T2all", "Long", limit=t2_level, qty_percent=100)
    else
        strategy.exit("T1",    "Long", limit=t1_level, qty_percent=34)
        strategy.exit("T2",    "Long", limit=t2_level, qty_percent=50)
        strategy.exit("Trail", "Long", trail_price=t2_level,
             trail_offset=trail_pct / 100 * entry_ref / syminfo.mintick)

if strategy.position_size == 0 and strategy.position_size[1] > 0
    line.delete(stop_line)
    line.delete(t1_line)
    line.delete(t2_line)
    line.delete(t3_line)
    stop_line := na
    t1_line   := na
    t2_line   := na
    t3_line   := na

// ─── SELL SIGNALS ────────────────────────────────────────────────────────────
// Helper: % gain from entry at current close
gain_now = na(entry_ref) or entry_ref == 0 ? 0.0 : (close - entry_ref) / entry_ref * 100
gain_str = (gain_now >= 0 ? "+" : "") + str.tostring(math.round(gain_now, 1)) + "%"

// T1 trim — position size shrank but didn't go to zero
t1_hit = strategy.position_size > 0 and strategy.position_size < strategy.position_size[1] and strategy.position_size[1] > 0
if t1_hit
    label.new(bar_index, high,
         "SELL T1 ⅓\n+" + str.tostring(t1_pct, "#") + "%\n$" + str.tostring(close, "#.##"),
         color=color.new(color.lime, 10), textcolor=color.black,
         style=label.style_label_down, size=size.normal)

// Full exit (T2, Stop, or any strategy close)
full_exit = strategy.position_size[1] > 0 and strategy.position_size == 0
if full_exit
    is_stop   = close <= stop_level * 1.01
    exit_col  = is_stop ? color.new(color.red, 0) : color.new(color.green, 10)
    exit_text = is_stop ? "SELL STOP\n" + gain_str + " ✗" :
         gain_now >= t2_pct * 0.9  ? "SELL T2 ✓\n" + gain_str :
         gain_now >= t1_pct * 0.9  ? "SELL T1 ✓\n" + gain_str :
         "SELL\n" + gain_str
    label.new(bar_index, high, exit_text + "\n$" + str.tostring(close, "#.##"),
         color=exit_col, textcolor=color.white,
         style=label.style_label_down, size=size.normal)

// SHA turns red 2 candles in a row — momentum fading, sell now
sha_sell = strategy.position_size > 0 and sha_red and sha_red[1]
if sha_sell
    label.new(bar_index, high,
         "SELL SHA\n" + gain_str,
         color=color.new(color.orange, 0), textcolor=color.white,
         style=label.style_label_down, size=size.small)

// K drops back below 20 — curl is done, sell now
k_sell = strategy.position_size > 0 and ta.crossunder(k, 20)
if k_sell
    label.new(bar_index, high,
         "SELL K<20\n" + gain_str,
         color=color.new(color.red, 10), textcolor=color.white,
         style=label.style_label_down, size=size.small)

// Price breaks below ZLSMA — trend broken, exit immediately
zlsma_sell = strategy.position_size > 0 and ta.crossunder(close, zlsma)
if zlsma_sell
    label.new(bar_index, low,
         "SELL ZLSMA\n" + gain_str,
         color=color.new(color.red, 0), textcolor=color.white,
         style=label.style_label_up, size=size.normal)

// ─── BUY LABEL ────────────────────────────────────────────────────────────────
if entry_signal
    label.new(bar_index, low,
         "BUY [" + session_tag + "]\n$" + str.tostring(close, "#.##") +
         "\nK=" + str.tostring(math.round(k, 1)),
         color=color.new(color.green, 10), textcolor=color.white,
         style=label.style_label_up, size=size.normal)

// Gray SKIP label — base signal fired but a filter blocked it
if base_signal and not entry_signal
    block_reason = not k_depth_ok ? "K too high\nbefore cross" : "Outside\ntime gate"
    label.new(bar_index, low, "SKIP\n" + block_reason,
         color=color.new(color.gray, 30), textcolor=color.white,
         style=label.style_label_up, size=size.tiny)

// ─── ALERTS ───────────────────────────────────────────────────────────────────
alertcondition(entry_signal,                     "BUY — Curl if Flow",      "W118 BUY {{ticker}} @ ${{close}} [" + session_tag + "] K=" + str.tostring(math.round(k,1)))
alertcondition(base_signal and not entry_signal, "SKIP — Signal Filtered",  "W118 SKIP {{ticker}} — base signal blocked by filter")
alertcondition(sha_sell,                         "SELL — SHA Turned Red",   "W118 SELL {{ticker}} SHA red — exit now @ ${{close}}")
alertcondition(k_sell,                           "SELL — K Dropped <20",    "W118 SELL {{ticker}} K below 20 — exit now @ ${{close}}")
alertcondition(zlsma_sell,                       "SELL — Below ZLSMA",      "W118 SELL {{ticker}} broke ZLSMA — exit now @ ${{close}}")
alertcondition(t1_hit,                           "SELL T1 — Trim 1/3",      "W118 SELL T1 {{ticker}} trim 1/3 @ ${{close}} (+15%)")
alertcondition(full_exit,                        "SELL — Position Closed",  "W118 CLOSED {{ticker}} @ ${{close}}")
alertcondition(k_curl_up and not price_in_flow,  "SKIP — Curl No Flow",     "W118 SKIP {{ticker}} curl but below ZLSMA-50")
